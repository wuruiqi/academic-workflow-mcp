# ── Obsidian Local REST API ────────────────────────────────────────────────
# Install "Local REST API" community plugin in Obsidian, then copy the key here.
OBSIDIAN_API_KEY=your_obsidian_api_key_here
OBSIDIAN_URL=http://127.0.0.1:27123

# Vault name used for obsidian:// deep-links (leave empty to disable)
OBSIDIAN_VAULT_NAME=Research

# Folder inside the vault where literature notes are stored
LITERATURE_FOLDER=10-Literature

# ── Zotero ────────────────────────────────────────────────────────────────
# Local API (read-only, no key needed — Zotero must be running)
ZOTERO_LOCAL_URL=http://127.0.0.1:23119

# Web API credentials (required for write operations: tags, child notes)
# Get your key at https://www.zotero.org/settings/keys
ZOTERO_API_KEY=your_zotero_api_key_here
ZOTERO_LIBRARY_ID=your_numeric_library_id
ZOTERO_LIBRARY_TYPE=user    # or "group"
